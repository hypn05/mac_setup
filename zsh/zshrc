# ~/.zshrc — symlinked here by modules/zsh.sh. Edit this file in the repo, not the symlink target.

# ── oh-my-zsh ────────────────────────────────────────────────────────────
export ZSH="$HOME/.oh-my-zsh"

# starship (initialized below) overrides the visual prompt whenever it's
# installed, so this theme only actually shows if starship is ever missing.
ZSH_THEME="jonathan"

HYPHEN_INSENSITIVE="true"     # `_` and `-` are interchangeable when tab-completing
COMPLETION_WAITING_DOTS="true" # show dots while waiting on a slow completion

# zsh-autosuggestions
ZSH_AUTOSUGGEST_STRATEGY=(history completion)
ZSH_AUTOSUGGEST_BUFFER_MAX_SIZE=20

# you-should-use (nudges you toward an existing alias after you type it out longhand)
YSU_MESSAGE_POSITION="after"
YSU_MODE=BESTMATCH

plugins=(
  git
  brew
  macos
  sudo
  colored-man-pages
  colorize
  dotenv
  python
  pip
  autojump
  zsh-autosuggestions
  zsh-syntax-highlighting
  kubectl
  fzf
  docker
  extract
  copyfile
  copypath
  alias-finder
  you-should-use
  fzf-tab   # must load after every other completion-touching plugin above
)

source "$ZSH/oh-my-zsh.sh"

# ── shell options ────────────────────────────────────────────────────────
setopt AUTO_CD               # `foo` cds into ./foo
setopt EXTENDED_GLOB          # advanced globbing patterns
setopt INTERACTIVE_COMMENTS   # allow trailing `# comments` typed at the prompt

HISTFILE="$HOME/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000
setopt EXTENDED_HISTORY        # timestamp each history entry
setopt HIST_EXPIRE_DUPS_FIRST  # trim duplicates before anything else
setopt HIST_IGNORE_DUPS        # skip immediate repeats
setopt HIST_IGNORE_SPACE       # skip lines starting with a space
setopt SHARE_HISTORY           # share history live across open sessions

# `menu no` looks backwards, but fzf-tab replaces the classic completion
# menu with its own fzf popup — leaving `menu select` on fights it.
zstyle ':completion:*' menu no
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always --icons $realpath 2>/dev/null'

# ── tool integrations ────────────────────────────────────────────────────
command -v starship >/dev/null 2>&1 && eval "$(starship init zsh)"
command -v zoxide >/dev/null 2>&1 && eval "$(zoxide init zsh)"
command -v direnv >/dev/null 2>&1 && eval "$(direnv hook zsh)"
# Takes over up-arrow and Ctrl+R history search (local-only by default; `atuin login` opts into sync).
command -v atuin >/dev/null 2>&1 && eval "$(atuin init zsh)"

# iTerm2 shell integration (installed by the iterm module): command status
# marks, jump-to-previous-prompt, instant replay.
[[ -f "$HOME/.iterm2_shell_integration.zsh" ]] && source "$HOME/.iterm2_shell_integration.zsh"

command -v fd >/dev/null 2>&1 && export FZF_DEFAULT_COMMAND='fd --type f --hidden --exclude .git'
[[ -n "${FZF_DEFAULT_COMMAND:-}" ]] && export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"

# ── modern CLI replacements ──────────────────────────────────────────────
command -v bat >/dev/null 2>&1 && alias cat='bat'
if command -v eza >/dev/null 2>&1; then
  alias ls='eza --icons'
  alias ll='eza -l --icons --git'
  alias la='eza -la --icons --git'
  alias lt='eza --tree --icons'
fi
command -v lazygit >/dev/null 2>&1 && alias lg='lazygit'

# ── local snippets (~/.zsh/*.zsh, e.g. shortcut.zsh) ─────────────────────
for _zsh_snippet in "$HOME"/.zsh/*.zsh(N); do
  source "$_zsh_snippet"
done
unset _zsh_snippet

# ── secrets (never committed — see zsh/zshrc.secrets.template) ──────────
[[ -f "$HOME/.zshrc.secrets" ]] && source "$HOME/.zshrc.secrets"
