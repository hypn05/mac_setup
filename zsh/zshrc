# ~/.zshrc — symlinked here by modules/zsh.sh. Edit this file in the repo, not the symlink target.

# ── oh-my-zsh ────────────────────────────────────────────────────────────
export ZSH="$HOME/.oh-my-zsh"

# Starship owns the prompt (initialized near the end). Empty OMZ theme avoids
# double prompt work; jonathan is available as a fallback only if you re-enable it.
ZSH_THEME=""

HYPHEN_INSENSITIVE="true"
COMPLETION_WAITING_DOTS="true"
DISABLE_UNTRACKED_FILES_DIRTY="true"   # faster git status in large repos
HIST_STAMPS="yyyy-mm-dd"

# zsh-autosuggestions
ZSH_AUTOSUGGEST_STRATEGY=(history completion)
ZSH_AUTOSUGGEST_BUFFER_MAX_SIZE=20

# you-should-use (nudge after you type a long form that has a shorter alias)
# BESTMATCH → prefer longest expansion (git status → gst, not g)
export YSU_MESSAGE_POSITION="after"
export YSU_MODE=BESTMATCH
export YSU_IGNORED_ALIASES=(g k)   # 1-letter aliases match everything

# fzf defaults (fd-backed when available)
export FZF_DEFAULT_OPTS='--height 40% --layout=reverse --border --info=inline --bind ctrl-j:down,ctrl-k:up'
if (( $+commands[fd] )); then
  export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
  export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
  export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'
fi

# Plugin order notes:
# - fzf-tab must load AFTER compinit (via oh-my-zsh) but BEFORE widgets that
#   wrap the line editor (autosuggestions / syntax-highlighting).
# - zsh-syntax-highlighting must be last overall.
plugins=(
  git
  kubectl
  fzf
  docker
  brew
  macos
  sudo
  extract
  copyfile
  copypath
  colored-man-pages
  colorize
  dotenv
  python
  pip
  alias-finder
  autojump
  fzf-tab
  zsh-autosuggestions
  you-should-use
  zsh-syntax-highlighting
)

source "$ZSH/oh-my-zsh.sh"

# ── shell options ────────────────────────────────────────────────────────
setopt AUTO_CD
setopt EXTENDED_GLOB
setopt INTERACTIVE_COMMENTS

HISTFILE="$HOME/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000
setopt EXTENDED_HISTORY
setopt HIST_EXPIRE_DUPS_FIRST
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt SHARE_HISTORY
setopt INC_APPEND_HISTORY

# fzf-tab replaces the classic completion menu
zstyle ':completion:*' menu no
if (( $+commands[eza] )); then
  zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath 2>/dev/null'
fi

# alias-finder: manual lookup (you-should-use handles automatic reminders)
# Usage: alias-finder git status
zstyle ':omz:plugins:alias-finder' longer yes
zstyle ':omz:plugins:alias-finder' exact yes

# Word movement (Ctrl+Left / Ctrl+Right)
bindkey '^[[1;5C' forward-word
bindkey '^[[1;5D' backward-word

# kubectl completion: cache to disk (plugin covers most; this is for full CLI).
# Regenerating every shell start is slow; refresh weekly or after kubectl upgrades.
if (( $+commands[kubectl] )); then
  _kubectl_comp_cache="${XDG_CACHE_HOME:-$HOME/.cache}/kubectl_zsh_completion"
  if [[ ! -s "$_kubectl_comp_cache" || -n "$_kubectl_comp_cache"(#qN.mh+168) ]]; then
    mkdir -p "${_kubectl_comp_cache:h}"
    kubectl completion zsh >|"$_kubectl_comp_cache" 2>/dev/null
  fi
  [[ -s "$_kubectl_comp_cache" ]] && source "$_kubectl_comp_cache"
  unset _kubectl_comp_cache
fi

# ── editor / venv-safe prompt ────────────────────────────────────────────
# Helix (hx) is the default terminal editor. Falls back to vim/vi.
if (( $+commands[hx] )); then
  export EDITOR="hx"
elif (( $+commands[vim] )); then
  export EDITOR="vim"
else
  export EDITOR="vi"
fi
export VISUAL="$EDITOR"
export GIT_EDITOR="$EDITOR"
export KUBE_EDITOR="$EDITOR"
export SUDO_EDITOR="$EDITOR"

if (( $+commands[bat] )); then
  export MANPAGER="sh -c 'col -bx | bat -l man -p'"
  export MANROFFOPT="-c"
fi

# Critical: set BEFORE any `source …/activate`.
# 1) Stops venv from rewriting PS1 (Starship shows .venv on the right).
# 2) Avoids activate's internal `deactivate` restoring a pre-Starship PS1.
export VIRTUAL_ENV_DISABLE_PROMPT=1

# ── tool integrations ────────────────────────────────────────────────────
# atuin takes over Ctrl+R / up-arrow history (local-only until `atuin login`).
command -v atuin >/dev/null 2>&1 && eval "$(atuin init zsh)"
command -v zoxide >/dev/null 2>&1 && eval "$(zoxide init zsh)"
command -v direnv >/dev/null 2>&1 && eval "$(direnv hook zsh)"

# iTerm2 shell integration (installed by the iterm module)
[[ -f "$HOME/.iterm2_shell_integration.zsh" ]] && source "$HOME/.iterm2_shell_integration.zsh"

# ── local snippets (~/.zsh/*.zsh, e.g. shortcuts.zsh) ────────────────────
# Source curated shortcuts + any extra drop-ins. Prefer plural name.
[[ -f "$HOME/.zsh/shortcuts.zsh" ]] && source "$HOME/.zsh/shortcuts.zsh"
[[ -f "$HOME/.zsh/shortcut.zsh" && ! -f "$HOME/.zsh/shortcuts.zsh" ]] && source "$HOME/.zsh/shortcut.zsh"
for _zsh_snippet in "$HOME"/.zsh/*.zsh(N); do
  case "$_zsh_snippet" in
    */shortcuts.zsh|*/shortcut.zsh) continue ;;  # already sourced above
    *) source "$_zsh_snippet" ;;
  esac
done
unset _zsh_snippet

# ── secrets (never committed — see zsh/zshrc.secrets.template) ──────────
[[ -f "$HOME/.zshrc.secrets" ]] && source "$HOME/.zshrc.secrets"

# ── Starship last so it owns the prompt ──────────────────────────────────
if command -v starship >/dev/null 2>&1; then
  eval "$(starship init zsh)"
  # Drop any pre-Starship saved PS1 so a later venv activate cannot restore it.
  unset _OLD_VIRTUAL_PS1
fi

# Optional global venv AFTER Starship (prompt-safe with VIRTUAL_ENV_DISABLE_PROMPT).
# Prefer project .venv via direnv; uncomment if you still want a default env:
# [[ -f "$HOME/.venv/bin/activate" ]] && source "$HOME/.venv/bin/activate" >/dev/null 2>&1

if [[ -o interactive ]]; then
  print -P "%F{8}tip:%f sc %F{8}(or%f shortcuts%f%F{8}) — browse aliases · you-should-use reminds when a shorter one exists · sc --live for all OMZ aliases%f"
fi
